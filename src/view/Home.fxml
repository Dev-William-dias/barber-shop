      <MenuBar layoutY="1.0" prefHeight="27.0" prefWidth="1000.0">
        <menus>
          <Menu mnemonicParsing="false" text="Cliente">
            <items>
                  <MenuItem mnemonicParsing="false" text="Agendar" />
              <MenuItem mnemonicParsing="false" text="Registrar" />
