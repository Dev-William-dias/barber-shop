<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane id="AnchorPane" prefHeight="425.0" prefWidth="400.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="controller.LoginController">
   <children>
      <ImageView fitHeight="425.0" fitWidth="400.0" pickOnBounds="true">
         <image>
            <Image url="@img/Barber-Shop.png" />
         </image>
      </ImageView>
      <TextField fx:id="txtUser" layoutX="54.0" layoutY="45.0" prefHeight="42.0" prefWidth="295.0" promptText="Usuario">
         <font>
            <Font size="16.0" />
         </font>
      </TextField>
      <PasswordField fx:id="txtPassword" layoutX="54.0" layoutY="140.0" prefHeight="42.0" prefWidth="295.0" promptText="Senha">
         <font>
            <Font size="16.0" />
         </font>
      </PasswordField>
      <Button fx:id="btnLogin" layoutX="101.0" layoutY="232.0" mnemonicParsing="false" prefHeight="42.0" prefWidth="200.0" text="Entrar">
         <font>
            <Font size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
